{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Code Pet",
  "version": "0.1.0",
  "identifier": "com.codepet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Code Pet",
        "url": "index.html",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true
      },
      {
        "label": "pet",
        "title": "Code Pet",
        "url": "pet.html",
        "width": 360,
        "height": 126,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/**",
          "$DATA/**",
          "$LOCALDATA/**",
          "$HOME/**",
          "$TEMP/**",
          "$RESOURCE/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": [
      "resources/sounds/whip-crack.wav",
      "resources/sounds/whip-swing.wav",
      "resources/sounds/whip-heavy-crack.wav"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
