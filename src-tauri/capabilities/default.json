{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default app permissions",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-resizable",
    "core:window:allow-start-dragging",
    "dialog:default",
    "opener:default",
    "shell:default"
  ]
}
