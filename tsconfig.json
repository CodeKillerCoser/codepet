{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "useDefineForClassFields": true
  },
  "include": ["frontend/**/*.ts", "frontend/**/*.svelte", "vite.config.ts"]
}
